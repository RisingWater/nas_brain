WXAUTO_API_URL=your_wxauto_server_url
WXAUTO_API_TOKEN=your_wxauto_server_token

LOG_DIR=logs
LOG_SIZE=20
LOG_BACKUPS=2
LOG_MAX_ENTRYS=20000

DB_PATH=data/nas_brain.db
DB_SERVICE_HOST=0.0.0.0
DB_SERVICE_PORT=9021

WEB_SERVICE_HOST=0.0.0.0
WEB_SERVICE_PORT=9020

SERVICE_MANAGER_HOST=0.0.0.0
SERVICE_MANAGER_PORT=9022
SERVICE_MANAGER_CONFIG=deploy/service_config.json

WECHAT_GATEWAY_HOST=0.0.0.0
WECHAT_GATEWAY_PORT=9030
WECHAT_POLL_INTERVAL=3

BRAIN_SERVICE_HOST=0.0.0.0
BRAIN_SERVICE_PORT=9031

# ---- 工具插件配置 ----
# 门禁开门
DOOR_OPEN_URL=
DOOR_OPEN_TOKEN=

# Home Assistant（空调/电视/PS5）
HOME_ASSISTANT_URL=
HOME_ASSISTANT_TOKEN=

# QB 设备定位（煜乔位置/电量）
QB_LOCATION_URL=
QB_LOCATION_USERNAME=
QB_LOCATION_PASSWORD=
QB_LOCATION_AUTHORITY=

# Claude CLI 路径（web_search 工具）
CLAUDE_BIN=claude

# 微信网关轮询账号
WECHAT_GATEWAY_WXNAME=

# 日志调试（默认输出到控制台）
LOG_CONSOLE=true
