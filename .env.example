# ---- 运行模式 ----
SINGLETON=1  # 1=单机（127.0.0.1 互连），0=多机（从 services_registry.json 读 IP）

# ---- Bot 身份 ----
BOT_NAME=NAS Brain         # AI 名称，用于默认 System Prompt
WECHAT_BOT_NAME=           # 微信名字，用于群聊 @ 检测（留空则不过滤）

# ---- WXAuto 微信自动化 ----
WXAUTO_API_URL=your_wxauto_server_url
WXAUTO_API_TOKEN=your_wxauto_server_token

# ---- DeepSeek AI ----
DEEPSEEK_API_KEY=

# ---- 日志 ----
LOG_DIR=logs
LOG_SIZE=20
LOG_BACKUPS=2
LOG_MAX_ENTRYS=20000
LOG_CONSOLE=true

# ---- 数据库微服务 ----
DB_PATH=data/nas_brain.db
DB_SERVICE_HOST=0.0.0.0
DB_SERVICE_PORT=9021

# ---- 管理后端微服务 ----
WEB_SERVICE_HOST=0.0.0.0
WEB_SERVICE_PORT=9020

# ---- 微服务管理器 ----
SERVICE_MANAGER_HOST=0.0.0.0
SERVICE_MANAGER_PORT=9022
SERVICE_MANAGER_CONFIG=deploy/service_config.json

# ---- 微信消息网关 ----
WECHAT_GATEWAY_HOST=0.0.0.0
WECHAT_GATEWAY_PORT=9030
WECHAT_GATEWAY_DUMP_MSG=0   # 设为 1 则在日志输出原始消息 JSON
WECHAT_POLL_INTERVAL=3

# ---- 大脑微服务 ----
BRAIN_SERVICE_HOST=0.0.0.0
BRAIN_SERVICE_PORT=9031

# ---- 音频播放微服务 ----
TTS_URL=your_easyvoice_api_url（不配置则仅缓存管理可用）
PLAYBACK_SERVICE_HOST=0.0.0.0
PLAYBACK_SERVICE_PORT=9041
TTS_CACHE_DIR=data/tts_cache
TTS_VOICE=zh-CN-XiaoxiaoNeural

# ---- 定时任务微服务 ----
SCHEDULE_SERVICE_PORT=9040

# ---- 工具插件 ----
# 门禁开门
DOOR_OPEN_URL=
DOOR_OPEN_TOKEN=

# DSM 门锁token
DSM_TOKEN=

# Home Assistant（空调/电视/PS5）
HOME_ASSISTANT_URL=
HOME_ASSISTANT_TOKEN=

# QB 设备定位（煜乔位置/电量）
QB_LOCATION_URL=
QB_LOCATION_USERNAME=
QB_LOCATION_PASSWORD=
QB_LOCATION_AUTHORITY=

# 网络搜索 Claude CLI 路径
CLAUDE_BIN=claude

# 默认城市（天气查询回退）
DEFAULT_CITY=
